# Supabase Configuration
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres"

# Upstash Redis Configuration
REDIS_URL="redis://default:[YOUR_TOKEN]@[YOUR_URL].upstash.io:6379"

# Auth Secrets
JWT_SECRET="super-secret-key-change-me"
JWT_REFRESH_SECRET="refresh-secret-key-change-me"

# Mail (Nodemailer via Gmail/SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ReCAPTCHA
RECAPTCHA_SITE_KEY="xxx"
RECAPTCHA_SECRET_KEY="xxx"

# Flutterwave
FLUTTER_WAVE_PUBLIC_KEY="FLWPUBK_TEST-xxx"
FLUTTER_WAVE_SECRET_KEY="FLWSECK_TEST-xxx"
FLUTTER_WAVE_ENCRYPTION_KEY="xxx"

# AWS S3 (Supabase S3 Compatible)
S3_ACCESS_KEY="xxx"
S3_SECRET_KEY="xxx"
S3_BUCKET="tutaly-assets"
S3_REGION="us-east-1"
S3_ENDPOINT="https://[YOUR_PROJECT_ID].supabase.co/storage/v1/s3"

